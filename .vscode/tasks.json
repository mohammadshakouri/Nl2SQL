{
	"version": "2.0.0",
	"tasks": [
		{
			"path": "frontend",
			"label": "client",
			"type": "npm",
			"script": "client",
			"isBackground": true,
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"options": {
				"cwd": "${workspaceFolder}/frontend"
			},

			// This task is run before some debug tasks.
			// Problem is, it's a watch script, and since it never exits, VSCode
			// complains. All this is needed so VSCode just lets it run.
			"problemMatcher": [
				{
					"pattern": [
						{
							"regexp": ".",
							"file": 1,
							"location": 2,
							"message": 3
						}
					],
					"background": {
						"activeOnStart": true,
						"beginsPattern": ".",
						"endsPattern": "."
					}
				}
			]
		},
		{
			"label": "terminate-client",
			"command": "${command:workbench.action.tasks.terminate}",
			"args": ["client"]
		}
	]
}
